--CONSULTAS--
--Usuarios con Roles--
SELECT u.nombre, r.nombre_rol
FROM usuarios u
JOIN usuario_rol ur
ON u.id_usuario = ur.id_usuario
JOIN roles r
ON ur.id_rol = r.id_rol;

--Reporte calidad del Aire--
SELECT e.nombre,
       m.fecha,
       m.pm25,
       m.pm10,
       m.ica
FROM medicion_aire m
JOIN estacion_aire e
ON m.id_estacion = e.id_estacion;

--Reporte calidad del Agua--
SELECT p.nombre,
       m.ph,
       m.temperatura,
       m.oxigeno_disuelto
FROM medicion_agua m
JOIN punto_agua p
ON m.id_punto = p.id_punto;
