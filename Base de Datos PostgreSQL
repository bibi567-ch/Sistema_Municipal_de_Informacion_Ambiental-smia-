CREATE TABLE usuarios (
    id_usuario SERIAL PRIMARY KEY,
    nombre VARCHAR(120) NOT NULL,
    apellido VARCHAR(120),
    correo VARCHAR(150) UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,
    telefono VARCHAR(20),
    estado BOOLEAN DEFAULT TRUE,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE roles (
    id_rol SERIAL PRIMARY KEY,
    nombre_rol VARCHAR(50) UNIQUE NOT NULL,
    descripcion TEXT
);

CREATE TABLE permisos (
    id_permiso SERIAL PRIMARY KEY,
    nombre_permiso VARCHAR(100) UNIQUE NOT NULL,
    descripcion TEXT
);

CREATE TABLE usuario_rol (
    id_usuario INT,
    id_rol INT,

    PRIMARY KEY(id_usuario, id_rol),

    FOREIGN KEY(id_usuario)
        REFERENCES usuarios(id_usuario)
        ON DELETE CASCADE,

    FOREIGN KEY(id_rol)
        REFERENCES roles(id_rol)
        ON DELETE CASCADE
);

CREATE TABLE rol_permiso (
    id_rol INT,
    id_permiso INT,

    PRIMARY KEY(id_rol, id_permiso),

    FOREIGN KEY(id_rol)
        REFERENCES roles(id_rol)
        ON DELETE CASCADE,

    FOREIGN KEY(id_permiso)
        REFERENCES permisos(id_permiso)
        ON DELETE CASCADE
);

CREATE TABLE auditoria (
    id_auditoria SERIAL PRIMARY KEY,
    id_usuario INT,
    accion VARCHAR(250),
    tabla_afectada VARCHAR(120),
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY(id_usuario)
        REFERENCES usuarios(id_usuario)
);

CREATE TABLE estacion_aire (
    id_estacion SERIAL PRIMARY KEY,
    nombre VARCHAR(100),
    zona VARCHAR(100),
    tipo_tecnologia VARCHAR(50),
    geom GEOGRAPHY(POINT,4326),
    estado BOOLEAN DEFAULT TRUE
);

CREATE TABLE medicion_aire (
    id_medicion SERIAL PRIMARY KEY,
    id_estacion INT,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    pm25 DECIMAL(10,2),
    pm10 DECIMAL(10,2),
    co DECIMAL(10,2),
    no2 DECIMAL(10,2),
    so2 DECIMAL(10,2),
    o3 DECIMAL(10,2),

    ica INT,

    FOREIGN KEY(id_estacion)
        REFERENCES estacion_aire(id_estacion)
);

CREATE TABLE punto_agua (
    id_punto SERIAL PRIMARY KEY,
    nombre VARCHAR(100),
    cuerpo_agua VARCHAR(120),
    geom GEOGRAPHY(POINT,4326)
);

CREATE TABLE medicion_agua (
    id_medicion SERIAL PRIMARY KEY,
    id_punto INT,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    ph DECIMAL(5,2),
    temperatura DECIMAL(5,2),
    oxigeno_disuelto DECIMAL(5,2),
    turbidez DECIMAL(5,2),
    conductividad DECIMAL(10,2),

    FOREIGN KEY(id_punto)
        REFERENCES punto_agua(id_punto)
);

CREATE TABLE operadores_residuos (
    id_operador SERIAL PRIMARY KEY,
    nombre_empresa VARCHAR(150),
    representante VARCHAR(120),
    telefono VARCHAR(30),
    direccion TEXT,
    tipo_residuo VARCHAR(120),
    autorizado BOOLEAN DEFAULT TRUE
);

CREATE TABLE generadores_residuos (
    id_generador SERIAL PRIMARY KEY,
    nombre VARCHAR(150),
    direccion TEXT,
    tipo_generador VARCHAR(100),
    geom GEOGRAPHY(POINT,4326)
);

CREATE TABLE ruteo_residuos (
    id_ruta SERIAL PRIMARY KEY,
    nombre_ruta VARCHAR(100),
    zona VARCHAR(100),
    frecuencia VARCHAR(50),
    descripcion TEXT
);

CREATE TABLE recoleccion_residuos (
    id_recoleccion SERIAL PRIMARY KEY,
    id_ruta INT,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    cantidad_kg DECIMAL(12,2),
    tipo_residuo VARCHAR(100),

    FOREIGN KEY(id_ruta)
        REFERENCES ruteo_residuos(id_ruta)
);

CREATE TABLE unidades_industriales (
    id_unidad SERIAL PRIMARY KEY,
    nombre VARCHAR(150),
    categoria VARCHAR(100),
    codigo_registro VARCHAR(100),
    fecha_registro DATE,
    macrodistrito VARCHAR(100),
    distrito VARCHAR(100),
    geom GEOGRAPHY(POINT,4326)
);

CREATE TABLE inspecciones (
    id_inspeccion SERIAL PRIMARY KEY,
    id_unidad INT,
    inspector INT,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    observaciones TEXT,
    resultado VARCHAR(100),

    FOREIGN KEY(id_unidad)
        REFERENCES unidades_industriales(id_unidad),

    FOREIGN KEY(inspector)
        REFERENCES usuarios(id_usuario)
);

CREATE TABLE monitoreo_acustico (
    id_monitoreo SERIAL PRIMARY KEY,
    zona VARCHAR(120),
    decibeles DECIMAL(6,2),
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    geom GEOGRAPHY(POINT,4326)
);

CREATE TABLE reportes (
    id_reporte SERIAL PRIMARY KEY,
    titulo VARCHAR(150),
    descripcion TEXT,
    fecha_generacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    generado_por INT,

    FOREIGN KEY(generado_por)
        REFERENCES usuarios(id_usuario)
);

CREATE TABLE solicitudes_ciudadanas (
    id_solicitud SERIAL PRIMARY KEY,
    nombre_ciudadano VARCHAR(150),
    correo VARCHAR(150),
    tipo_solicitud VARCHAR(120),
    descripcion TEXT,
    estado VARCHAR(50) DEFAULT 'PENDIENTE',
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE documentos (
    id_documento SERIAL PRIMARY KEY,
    titulo VARCHAR(200),
    archivo TEXT,
    fecha_subida TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    subido_por INT,

    FOREIGN KEY(subido_por)
        REFERENCES usuarios(id_usuario)
);

-- ÍNDICES --
CREATE INDEX idx_usuario_correo
ON usuarios(correo);

CREATE INDEX idx_medicion_aire_fecha
ON medicion_aire(fecha);

CREATE INDEX idx_medicion_agua_fecha
ON medicion_agua(fecha);

CREATE INDEX idx_inspecciones_fecha
ON inspecciones(fecha);

--INDICES ESPACIALES GIS--
CREATE INDEX idx_estacion_geom
ON estacion_aire
USING GIST(geom);

CREATE INDEX idx_puntoagua_geom
ON punto_agua
USING GIST(geom);

CREATE INDEX idx_industria_geom
ON unidades_industriales
USING GIST(geom);

--PROCEDIMIENTO AUDITORIA--
CREATE OR REPLACE PROCEDURE registrar_auditoria(
    p_usuario INT,
    p_accion VARCHAR,
    p_tabla VARCHAR
)
LANGUAGE plpgsql
AS $$
BEGIN

INSERT INTO auditoria(
    id_usuario,
    accion,
    tabla_afectada
)
VALUES(
    p_usuario,
    p_accion,
    p_tabla
);

END;
$$;

