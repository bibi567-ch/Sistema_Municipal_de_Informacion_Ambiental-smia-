--registrar auditoria--

CREATE PROCEDURE sp_registrar_auditoria
    @id_usuario INT,
    @accion VARCHAR(200),
    @tabla VARCHAR(100)
AS
BEGIN
    INSERT INTO Auditoria (id_usuario, accion, tabla_afectada)
    VALUES (@id_usuario, @accion, @tabla);
END;

--verificar permisos--

CREATE PROCEDURE sp_verificar_permiso
    @id_usuario INT,
    @permiso VARCHAR(100)
AS
BEGIN
    SELECT p.nombre_permiso
    FROM Usuarios u
    JOIN Usuario_Rol ur ON u.id_usuario = ur.id_usuario
    JOIN Roles r ON ur.id_rol = r.id_rol
    JOIN Rol_Permiso rp ON r.id_rol = rp.id_rol
    JOIN Permisos p ON rp.id_permiso = p.id_permiso
    WHERE u.id_usuario = @id_usuario
    AND p.nombre_permiso = @permiso;
END;

